{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/",
      "dest": "public/home.html"
    },
    {
      "src": "/admin/(.*)",
      "dest": "public/admin_$1"
    },
    {
      "src": "/client/(.*)",
      "dest": "public/client_$1"
    },
    {
      "src": "/(.*)\\.js",
      "dest": "public/$1.js"
    },
    {
      "src": "/(.*)\\.css",
      "dest": "public/$1.css"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    },
    {
      "src": "/(.+)",
      "dest": "public/$1"
    }
  ]
}
